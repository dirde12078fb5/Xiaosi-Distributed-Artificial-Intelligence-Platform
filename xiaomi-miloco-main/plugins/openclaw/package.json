{
  "name": "miloco-openclaw-plugin",
  "version": "0.0.1",
  "description": "Xiaomi Miloco plugin for OpenClaw",
  "keywords": [
    "miloco",
    "openclaw",
    "miloco-openclaw-plugin"
  ],
  "author": "Miloco team <xiaomi-miloco@xiaomi.com>",
  "license": "MIT",
  "homepage": "https://git.n.xiaomi.com/miloco/miloco-plugin",
  "repository": {
    "type": "git",
    "url": "git@git.n.xiaomi.com:miloco/miloco-plugin.git"
  },
  "bugs": {
    "url": "https://git.n.xiaomi.com/miloco/miloco-plugin/-/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-skills.mjs",
    "build": "tsdown",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "lint": "biome check --write --no-errors-on-unmatched --diagnostic-level=error ."
  },
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "ajv": "^8.20.0",
    "json-schema-to-ts": "^3.1.1",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.5.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.mjs"
    ],
    "install": {
      "npmSpec": "miloco-openclaw-plugin",
      "localPath": "extensions/miloco-openclaw-plugin",
      "defaultChoice": "npm"
    }
  }
}
