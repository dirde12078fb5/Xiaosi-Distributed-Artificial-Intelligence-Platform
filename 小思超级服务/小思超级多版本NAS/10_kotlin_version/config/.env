# 小思超级NAS - Kotlin版本配置文件

# 服务器配置
PORT=8080
HOST=0.0.0.0

# 路径配置
STORAGE_PATH=./storage
TEMP_PATH=./temp

# JWT配置 (密钥长度必须足够用于HS256算法)
JWT_SECRET=xiaosi-super-nas-secret-key-2024-kotlin-must-be-long-enough-for-hs256-algorithm
JWT_EXPIRY_HOURS=24

# 文件配置 (最大上传文件大小，单位：字节)
MAX_FILE_SIZE=1073741824

# 默认用户配置
DEFAULT_USER=admin
DEFAULT_PASSWORD=admin123
