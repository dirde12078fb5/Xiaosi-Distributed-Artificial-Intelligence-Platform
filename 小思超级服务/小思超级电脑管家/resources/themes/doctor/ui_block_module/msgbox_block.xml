<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box bkcolor="bk_wnd_msg_darkcolor" width="stretch" height="stretch">
		<VBox bkcolor="white" name="msgbox" width="450" height="auto" valign="center" halign="center" visible="true" borderround="10,10" padding="24,30,24,30">
			<Label class="text_black_14" name="msg_title" width="stretch" height="auto"/>
			<VBox width="stretch" height="auto" margin="0,10,0,0" name="detect_normal_div">
				<CheckBox class="checkbox_normal" width="auto" name="checkbox" textid="STRING_TAB_BLOCK_MODULE_TEXT_MSG_BOX_DETECT_NORMAL"/>
				<Label class="text_path" margin="0,5,0,0" name="detect_normal_dlls" width="stretch" height="auto"/>
			</VBox>
			<VBox width="stretch" height="auto" margin="0,10,0,0" name="detect_boost_div">
				<HBox width="auto" height="auto">
					<CheckBox class="checkbox_normal" width="auto" name="checkbox" textid="STRING_TAB_BLOCK_MODULE_TEXT_MSG_BOX_DETECT_BOOST"/>
					<Label class="text_path" margin="5,0,0,0" name="detect_boost_tips" width="auto" height="auto"/>
				</HBox>
				<Label class="text_path" margin="0,5,0,0" name="detect_boost_dlls" width="stretch" height="auto"/>
			</VBox>
			<Control name="stretch"/>
			<HBox margin="0,10,0,0" valign="bottom" halign="right" width="auto" height="auto">
				<ButtonEx class="btn_gray_font12" textpadding="20,8,20,8" name="btn_left_text" textid="STRING_CANCEL" width="auto" height="auto"/>
				<Control name="stretch" width="15"/>
				<ButtonEx class="btn_blue_font12" textpadding="20,8,20,8" name="btn_right_text" textid="STRING_OK" width="auto" height="auto"/>
			</HBox>
		</VBox>
	</Box>
</Window>