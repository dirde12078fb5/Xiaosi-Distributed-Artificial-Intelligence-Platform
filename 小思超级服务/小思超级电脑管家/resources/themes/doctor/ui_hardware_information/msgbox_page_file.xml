<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box bkcolor="bk_wnd_msg_darkcolor" width="stretch" height="stretch">
		<VBox bkcolor="white" name="msgbox" width="720" height="auto" valign="center" halign="center" visible="true" borderround="10,10">
			<Button class="btn_wnd_close" valign="top" halign="right" name="msg_cls_btn" margin="0,10,10,0"/>
			<VBox margin="24,4,24,24" width="stretch" height="auto">
				<Label font="system_bold_20" name="msg_title" width="stretch" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_TITLE"/>
				<Control height="12"/>
				<Label font="system_bold_14" width="stretch" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_SECTION_AUTO_MANAGE"/>
				<Control height="8"/>
				<CheckBox class="checkbox_normal" width="auto" valign="center" name="chk_auto_manage" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_AUTO_MANAGE"/>
				<Control class="splitline_hor_level1" margin="0,12,0,12"/>
				<Label font="system_bold_14" width="stretch" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_SECTION_MANUAL_MANAGE"/>
				<Control height="8"/>
				<HBox width="stretch" height="auto">
					<Label font="system_bold_14" name="label_drive" width="auto" height="auto" valign="center"/>
					<Control width="8"/>
					<Combo vscrollbar="false" margin="0,0,0,0" name="combo_drive" valign="center" width="120" height="24" dropboxsize="0,9999999" borderround="4,4" bordersize="1" bordercolor="color_btn_border" bkimage="file='combox.svg' dest='96,0,120,24'"/>
					<Control width="stretch"/>
				</HBox>
				<HBox width="stretch" height="auto">
					<Label font="system_12" normaltextcolor="gray" width="auto" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_FREE_SPACE"/>
					<Control width="6"/>
					<Label font="system_12" normaltextcolor="darkcolor" name="label_drive_free_space" width="auto" height="auto"/>
				</HBox>
				<Control height="8"/>
				<VBox width="stretch" height="auto" childmargin="10">
					<HBox width="stretch" height="auto">
						<CheckBox class="checkbox_normal" width="auto" valign="center" name="chk_custom" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_CUSTOM"/>
						<Label width="16" height="16" margin="6,0,0,0" valign="center" halign="center" text="?" font="system_bold_12" normaltextcolor="gray" hotcolor="color_text_item_hot" cursortype="hand" tooltiptextid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_TIP_CUSTOM"/>
						<Control width="12"/>
						<Label width="auto" valign="center" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_INITIAL_MB"/>
						<Control width="6"/>
						<Box borderround="8,8" bordersize="1" bordercolor="splitline_level1" valign="center" width="120" height="30">
							<NumberEdit name="edit_initial" margin="12,0,0,0" font="system_14" valign="center" width="stretch" height="auto" normaltextcolor="black" multiline="false" intonly="true" allownegative="false"/>
						</Box>
						<Control width="12"/>
						<Label width="auto" valign="center" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_MAX_MB"/>
						<Control width="6"/>
						<Box borderround="8,8" bordersize="1" bordercolor="splitline_level1" valign="center" width="120" height="30">
							<NumberEdit name="edit_max" margin="12,0,0,0" font="system_14" valign="center" width="stretch" height="auto" normaltextcolor="black" multiline="false" intonly="true" allownegative="false"/>
						</Box>
					</HBox>
					<HBox width="stretch" height="auto">
						<CheckBox class="checkbox_normal" width="auto" valign="center" name="chk_system_managed" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_SYSTEM_MANAGED"/>
						<Label width="16" height="16" margin="6,0,0,0" valign="center" halign="center" text="?" font="system_bold_12" normaltextcolor="gray" hotcolor="color_text_item_hot" cursortype="hand" tooltiptextid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_TIP_SYSTEM_MANAGED"/>
					</HBox>
					<HBox width="stretch" height="auto">
						<CheckBox class="checkbox_normal" width="auto" valign="center" name="chk_none" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_NONE"/>
						<Label width="16" height="16" margin="6,0,0,0" valign="center" halign="center" text="?" font="system_bold_12" normaltextcolor="gray" hotcolor="color_text_item_hot" cursortype="hand" tooltiptextid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_TIP_NONE"/>
					</HBox>
				</VBox>
				<Control class="splitline_hor_level1" margin="0,12,0,12"/>
				<Label font="system_bold_14" width="stretch" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_SECTION_RECOMMENDED"/>
				<Control height="2"/>
				<Label font="system_12" normaltextcolor="gray" width="stretch" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_DIALOG_RECOMMENDED_DESC"/>
				<Control height="8"/>
				<HBox width="stretch" height="auto">
					<Label font="system_12" normaltextcolor="gray" width="auto" height="auto" textid="STRING_TAB_SYSTEM_INFO_PAGE_FILE_MIN_RECOMMENDED"/>
					<Control width="6"/>
					<Label font="system_12" normaltextcolor="darkcolor" name="label_min_recommended_value" width="auto" height="auto"/>
				</HBox>
				<HBox width="stretch" height="auto" margin="0,6,0,0">
					<Label font="system_12" normaltextcolor="gray" width="auto" height="auto" textid="STRING_TAB_SYSTEM_INFO_RECOMMENDED"/>
					<Control width="6"/>
					<Label font="system_12" normaltextcolor="darkcolor" name="label_recommended_value" width="auto" height="auto"/>
				</HBox>
				<Control height="18"/>
				<HBox height="30">
					<Control width="stretch"/>
					<ButtonEx class="normal_button" textpadding="20,0,20,0" width="auto" height="30" name="btn_ok" textid="STRING_SAVE"/>
				</HBox>
			</VBox>
		</VBox>
	</Box>
</Window>
