<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<ListContainerElement class="listitem" name="list_item" width="stretch" height="auto">
		<HBox width="stretch" height="auto">
			<Label class="text_path" name="item_info" textpadding="0,2,0,2" font="system_12" normaltextcolor="darkcolor" width="auto" height="auto" valign="center"/>
			<Label name="item_help"
			       width="16"
			       height="16"
			       margin="8,0,0,0"
			       text="?"
			       font="system_bold_12"
			       normaltextcolor="dark_gray"
			       hotcolor="color_text_item_hot"
			       halign="center"
			       valign="center"
			       cursortype="hand"
			       mouse="true"/>
			<ButtonEx class="normal_button" name="btn_action" width="auto" minwidth="60" height="22" margin="6,0,0,0" textpadding="8,0,8,0" valign="center"/>
			<Control width="stretch"/>
		</HBox>
	</ListContainerElement>
</Window>
