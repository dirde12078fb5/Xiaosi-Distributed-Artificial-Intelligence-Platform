<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Box margin="0,0,0,0" valign="center" halign="center" width="stretch" height="stretch">
        <VBox margin="0,0,0,0" padding="25,25,25,25">
            <VBox margin="0,0,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <HBox margin="0,2,0,0" mouse="false" width="auto" height="auto" halign="left">
                    <Box borderround="8,8" bordersize="1" bordercolor="splitline_level1" valign="center" width="300" height="30">
                        <RichEdit name="detect_url_edit" margin="12,0,0,0" font="system_14" valign="center"
                                  width="stretch" height="auto" normaltextcolor="black" multiline="false"
                                  promptmode="true" promptcolor="splitline_level1" prompttext="www.example.com"/>
                    </Box>
                    <Button class="normal_button" name="detect_button" width="auto" minwidth="80" height="30"
                            margin="10,0,0,0" valign="center" textid="STRING_TAB_NETWORK_DIAGNOSIS_START_DETECT"/>
                    <Button class="normal_button" name="cancel_button" width="auto" minwidth="80" height="30"
                            margin="10,0,0,0" valign="center" textid="STRING_TAB_NETWORK_DIAGNOSIS_CANCEL"/>
                </HBox>
            </VBox>
            <VBox margin="0,25,0,0" padding="12,12,12,12" height="stretch" bkcolor="white" borderround="8,8"
                  bordersize="1" bordercolor="splitline_level1">
                <HBox margin="0,0,0,0" padding="0,0,0,0" height="auto">
                    <Label name="detect_status" mouse="false" width="16" height="16" valign="center"
                           halign="center"/>
                    <Label margin="4,0,0,0" mouse="false" height="auto"
                           textid="STRING_TAB_NETWORK_DIAGNOSIS_DETECT_RESULT"
                           font="system_14" valign="center"/>
                </HBox>
                <VListBox class="list" name="detect_list" margin="0,10,0,0" width="stretch" height="stretch"
                          vscrollbar="true" hscrollbar="true"/>
            </VBox>
        </VBox>
    </Box>
</Window>