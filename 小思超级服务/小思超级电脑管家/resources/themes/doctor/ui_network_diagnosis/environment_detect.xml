<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Box margin="0,0,0,0" valign="center" halign="center" width="stretch" height="stretch">
        <VBox margin="0,0,0,0" padding="25,25,25,25" height="auto">
            <VBox margin="0,0,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <Button class="normal_button" name="detect_button" width="auto" minwidth="80" height="30"
                        margin="0,0,0,0" valign="center" halign="left"
                        textid="STRING_TAB_NETWORK_DIAGNOSIS_START_DETECT"/>
                <Button class="normal_button" name="cancel_button" width="auto" minwidth="80" height="30"
                        margin="0,0,0,0" valign="center" halign="left"
                        textid="STRING_TAB_NETWORK_DIAGNOSIS_CANCEL"/>
            </VBox>
            <VBox margin="0,25,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <HBox margin="0,0,0,0" padding="0,0,0,0" height="auto">
                    <Label name="basic_info_status" mouse="false" width="16" height="16" valign="center"
                           halign="center"/>
                    <Label margin="4,0,0,0" mouse="false" height="auto" font="system_14"
                           textid="STRING_TAB_NETWORK_DIAGNOSIS_BASIC_NETWORK_ENVIRONMENT_INFO" valign="center"/>
                </HBox>
                <VListBox class="list" name="basic_info_list" margin="0,10,0,0" width="stretch" height="auto"
                          vscrollbar="true"/>
            </VBox>
            <VBox margin="0,25,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <HBox margin="0,0,0,0" padding="0,0,0,0" height="auto">
                    <Label name="common_domain_detect_status" mouse="false" width="16" height="16" valign="center"/>
                    <Label margin="4,0,0,0" mouse="false" height="auto" font="system_14"
                           textid="STRING_TAB_NETWORK_DIAGNOSIS_COMMON_DOMAIN_DETECT" valign="center"/>
                </HBox>
                <VListBox class="list" name="common_domain_detect_list" margin="0,10,0,0" width="stretch" height="auto"
                          vscrollbar="true"/>
            </VBox>
            <VBox margin="0,25,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <HBox margin="0,0,0,0" padding="0,0,0,0" height="auto">
                    <Label name="download_speed_test_status" mouse="false" width="16" height="16" valign="center"/>
                    <Label margin="4,0,0,0" mouse="false" height="auto" font="system_14"
                           textid="STRING_TAB_NETWORK_DIAGNOSIS_DOWNLOAD_SPEED_TEST" valign="center"/>
                </HBox>
                <Control class="splitline_hor_level1" name="split_line"/>
                <VBox height="auto" bkcolor="white" borderround="8,8" bordersize="1" margin="0,6,0,0">
                    <Label name="download_speed_detail_info" font="system_12" margin="4,0,0,0" mouse="false" height="auto" valign="center"/>
                    <HBox name="download_speed_desc_div" margin="4,0,0,0" width="auto" height="auto" mouse="false">
                        <Label textid="STRING_TAB_NETWORK_DIAGNOSIS_DOWNLOAD_TEST_DESC" font="system_12" mouse="false" height="auto" valign="center"/>
                        <RichEdit name="download_speed_desc" margin="2,0,0,0" align="vcenter" readonly="true" width="999999" height="24" valign="center" normaltextcolor="black" multiline="false"/>
                    </HBox>
                </VBox>
                <VListBox class="list" name="download_speed_test_list" margin="0,5,0,0" width="stretch" height="auto"
                          vscrollbar="true"/>
            </VBox>
        </VBox>
    </Box>
</Window>