<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <ListContainerElement class="listitem" width="stretch" height="auto">
        <VBox width="stretch" height="auto" padding="0,0,0,0" bordercolor="color_btn_border"
              bordersize="0,1,0,0">
            <HBox width="auto" minheight="40" height="stretch" valign="center" halign="left" padding="0,0,0,0"
                  bordercolor="color_btn_border">
                <HBox margin="0,0,0,0" width="16" height="stretch" valign="center" halign="center">
                    <Button class="btn_expand_right" width="16" height="16" name="btn_expand" valign="center"
                            halign="center"/>
                    <Button class="btn_contract" width="16" height="16" name="btn_contract" valign="center"
                            halign="center"/>
                </HBox>
                <Label name="url" valign="center" halign="center" height="auto" width="200"
                       endellipsis="true" margin="0,0,8,0"/>
                <Label name="status" valign="center" halign="center" height="auto" width="60"
                       borderround="6,6"
                       singleline="true" textpadding="4,0,4,0" margin="0,0,8,0"/>
                <Label name="ip_info" valign="center" halign="center" height="auto" width="300"
                       singleline="true" endellipsis="true" margin="0,0,8,0"/>
                <Label name="network_error" valign="center" halign="center" height="auto" width="80"
                       singleline="true" endellipsis="true" margin="0,0,8,0"/>
                <Label name="protocol" valign="center" halign="center" height="auto" width="80"
                       singleline="true" endellipsis="true" margin="0,0,8,0"/>
                <Label name="request_cost" valign="center" halign="center" height="auto" width="80"
                       singleline="true" endellipsis="true" margin="0,0,8,0"/>
                <Label name="connect_cost" valign="center" halign="center" height="auto" width="120"
                       singleline="true" endellipsis="true" margin="0,0,8,0"/>
                <Label name="error_label" valign="center" halign="center" height="auto" width="400"
                       singleline="false" endellipsis="true" margin="0,0,8,0"/>
            </HBox>
            <HBox name="detail_box" margin="16,0,0,0" width="stretch" height="auto" valign="center" halign="left">
                <VBox width="350" margin="0,10,0,0" height="auto" padding="0,0,0,0" bordercolor="color_btn_border" bordersize="0,1,0,0">
                     <Box margin="0,0,0,0" width="auto" height="40" halign="left" bordercolor="color_btn_border" bordersize="0,1,0,0">
                         <Label valign="center" halign="left" name="detail_label_title" width="auto" height="auto" singleline="true"/>
                     </Box>
                     <Label valign="center" halign="left" name="detail_label" margin="0,0,0,0" width="350" height="auto"
                            singleline="false" bordercolor="color_btn_border" bordersize="0,1,0,0"/>
               </VBox>
               <VListBox name="detail_detect_list" margin="0,10,0,0" width="stretch" height="stretch"
                          vscrollbar="true" hscrollbar="true" halign="left" valign="top"/>
            </HBox>
        </VBox>
    </ListContainerElement>
</Window>