<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box margin="0,0,0,0" valign="center" halign="center" width="stretch" height="stretch">
		<VBox margin="0,0,0,0" padding="25,25,25,25">
			<VBox name="startup_cost_panel" margin="0,0,0,12" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8"
				  bordersize="1" bordercolor="splitline_level1">
				<VBox width="stretch" height="auto" margin="4,0,0,8" mouse="false">
					<HBox name="startup_cost_rating_box" width="auto" height="auto" halign="left" valign="center" visible="false">
						<Label name="startup_cost_rating_title" font="system_bold_14" height="auto" width="auto" textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_COST_RATING_FMT"/>
						<Label name="startup_cost_rating_value" font="system_bold_14" height="auto" width="auto" margin="4,0,0,0"/>
					</HBox>
				</VBox>
				<HBox width="stretch" height="auto" margin="4,0,0,0" mouse="false">
					<Label name="startup_cost_total" font="system_bold_12" height="auto" width="auto" align="left" singleline="true" endellipsis="true"/>
					<Label name="startup_cost_summary" font="system_12" height="auto" width="stretch" margin="8,0,0,0" align="left" singleline="true" endellipsis="true"/>
				</HBox>
				<HBox name="shutdown_cost_panel" width="stretch" height="auto" margin="4,4,0,0" halign="left" valign="center" visible="false">
					<Label name="shutdown_cost_prefix" font="system_12" height="auto" width="auto"/>
					<Label name="shutdown_cost_rating_value" font="system_12" height="auto" width="auto" margin="4,0,0,0"/>
				</HBox>
				<VBox name="startup_impact_panel" margin="0,8,0,0" width="stretch" height="auto">
					<HBox width="auto" height="auto" margin="4,4,0,6" halign="left" valign="center" mouse="false">
						<Label font="system_bold_12" height="auto" width="auto" textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_IMPACT_APPS_TITLE"/>
						<Label name="startup_impact_count_label" font="system_12" height="auto" width="auto" margin="8,0,0,0" normaltextcolor="gray"/>
					</HBox>
					<HBox margin="3,1,1,0" mouse="false" width="auto" height="auto" halign="left">
						<Control width="20" height="30"/>
						<ButtonEx name="startup_impact_name_button" class="tab_header_button" width="180" height="30"
								  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_IMPACT_APPS_NAME" font="system_bold_12" mouse="false"/>
						<ButtonEx name="startup_impact_time_button" class="tab_header_button" width="140" height="30"
								  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_IMPACT_APPS_TIME" font="system_bold_12" mouse="false"/>
						<ButtonEx name="startup_impact_delta_button" class="tab_header_button" width="140" height="30"
								  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_IMPACT_APPS_DELTA" font="system_bold_12" mouse="false"/>
						<ButtonEx name="startup_impact_company_button" class="tab_header_button" width="240" height="30"
								  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_IMPACT_APPS_COMPANY" font="system_bold_12" mouse="false"/>
						<ButtonEx name="startup_impact_path_button" class="tab_header_button" width="640" height="30"
								  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_STARTUP_IMPACT_APPS_PATH" font="system_bold_12" mouse="false"/>
					</HBox>
					<VListBox class="list" name="startup_impact_list" margin="0,0,1,0" width="stretch" height="auto"
							  vscrollbar="false" hscrollbar="true"/>
				</VBox>
			</VBox>
			<VBox name="autorun_analysis_panel" margin="0,0,0,0" padding="12,12,12,12" height="stretch" bkcolor="white" borderround="8,8"
				  bordersize="1" bordercolor="splitline_level1">
				<Label name="autorun_analysis_title" font="system_bold_14" margin="4,0,0,8" textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_ANALYSIS_TITLE"/>
				<VBox width="stretch" height="stretch" margin="0,0,0,0" padding="1,1,1,1" bkcolor="white" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
					<HListBox margin="0,0,0,0" name="autorun_analysis_tab" width="stretch" height="auto" hscrollbar="true" defaultdisplayscrollbar="true"/>
					<Control class="splitline_hor_level1"/>
					<Box name="autorun_analysis_content" margin="3,5,0,0" width="stretch" height="stretch">
						<VBox name="autorun_apps_panel" width="stretch" height="stretch">
							<HBox width="stretch" height="30" margin="0,0,0,8" halign="left" valign="center" mouse="false">
								<Label name="autorun_apps_count_label" font="system_14" height="auto" width="auto" normaltextcolor="gray"/>
								<Control name="stretch"/>
								<ButtonEx class="normal_button" valign="center" halign="right" textpadding="20,0,20,0" width="auto" height="30" name="btn_disable_autorun" textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_DISABLE_BUTTON"/>
							</HBox>
							<HBox margin="3,1,1,0" mouse="false" width="auto" height="auto" halign="left">
								<Control width="20" height="30"/>
								<ButtonEx name="entry_name_button" class="tab_header_button" width="180" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_ENTRY_NAME" font="system_bold_12" mouse="false"/>
								<ButtonEx name="description_button" class="tab_header_button" width="280" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_DESCRIPTION" font="system_bold_12" mouse="false"/>
								<ButtonEx name="publisher_button" class="tab_header_button" width="240" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_PUBLISHER" font="system_bold_12" mouse="false"/>
								<ButtonEx name="image_path_button" class="tab_header_button" width="640" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_IMAGE_PATH" font="system_bold_12" mouse="false"/>
							</HBox>
							<VListBox class="list" name="autorun_apps_list" margin="0,0,1,0" width="stretch" height="stretch" vscrollbar="true" hscrollbar="true"/>
						</VBox>
						<VBox name="autorun_services_panel" width="stretch" height="stretch" visible="false">
							<HBox width="stretch" height="30" margin="0,0,0,8" halign="left" valign="center" mouse="false">
								<Label name="autorun_services_count_label" font="system_14" height="auto" width="auto" normaltextcolor="gray"/>
								<Control name="stretch"/>
							</HBox>
							<HBox margin="3,1,1,0" mouse="false" width="auto" height="auto" halign="left">
								<Control width="20" height="30"/>
								<ButtonEx name="service_entry_name_button" class="tab_header_button" width="180" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_ENTRY_NAME" font="system_bold_12" mouse="false"/>
								<ButtonEx name="service_description_button" class="tab_header_button" width="280" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_DESCRIPTION" font="system_bold_12" mouse="false"/>
								<ButtonEx name="service_publisher_button" class="tab_header_button" width="240" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_PUBLISHER" font="system_bold_12" mouse="false"/>
								<ButtonEx name="service_image_path_button" class="tab_header_button" width="640" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_IMAGE_PATH" font="system_bold_12" mouse="false"/>
							</HBox>
							<VListBox class="list" name="autorun_services_list" margin="0,0,1,0" width="stretch" height="stretch" vscrollbar="true" hscrollbar="true"/>
						</VBox>
						<VBox name="autorun_drivers_panel" width="stretch" height="stretch" visible="false">
							<HBox width="stretch" height="30" margin="0,0,0,8" halign="left" valign="center" mouse="false">
								<Label name="autorun_drivers_count_label" font="system_14" height="auto" width="auto" normaltextcolor="gray"/>
								<Control name="stretch"/>
							</HBox>
							<HBox margin="3,1,1,0" mouse="false" width="auto" height="auto" halign="left">
								<Control width="20" height="30"/>
								<ButtonEx name="driver_entry_name_button" class="tab_header_button" width="180" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_ENTRY_NAME" font="system_bold_12" mouse="false"/>
								<ButtonEx name="driver_description_button" class="tab_header_button" width="280" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_DESCRIPTION" font="system_bold_12" mouse="false"/>
								<ButtonEx name="driver_publisher_button" class="tab_header_button" width="240" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_PUBLISHER" font="system_bold_12" mouse="false"/>
								<ButtonEx name="driver_image_path_button" class="tab_header_button" width="640" height="30"
										  textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_AUTORUN_APPS_IMAGE_PATH" font="system_bold_12" mouse="false"/>
							</HBox>
							<VListBox class="list" name="autorun_drivers_list" margin="0,0,1,0" width="stretch" height="stretch" vscrollbar="true" hscrollbar="true"/>
						</VBox>
					</Box>
				</VBox>
			</VBox>
		</VBox>
	</Box>
</Window>
