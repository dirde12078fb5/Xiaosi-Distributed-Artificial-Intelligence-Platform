<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Box margin="0,0,0,0" valign="center" halign="center" width="stretch" height="stretch">
        <VBox margin="0,0,0,0" padding="25,25,25,25">
            <VBox margin="0,0,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <HBox margin="0,0,0,0" mouse="false" width="stretch" height="auto" halign="right">
                    <CheckBox class="list_tab_checkbox" name="show_item_without_display_name_checkbox"
                              width="16" height="16" align="left" valign="center"/>
                    <Label width="auto" margin="2,0,2,0" align="left" valign="center"
                           textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_SHOW_ITEM_WITHOUT_DISPLAY_NAME"/>
                    <CheckBox class="list_tab_checkbox" name="show_system_component_checkbox"
                              width="16" height="16" align="left" valign="center"/>
                    <Label width="auto" margin="2,0,2,0" align="left" valign="center"
                           textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_SHOW_SYSTEM_COMPONENT"/>
                    <HBox width="stretch"/>
                    <Button class="normal_button" name="refresh_button" width="auto" minwidth="80" height="30"
                            margin="0,0,0,0" valign="center" textid="STRING_REFRESH"/>
                </HBox>
            </VBox>
            <VBox margin="0,25,0,0" padding="12,0,12,12" height="stretch" bkcolor="white" borderround="8,8"
                  bordersize="1" bordercolor="splitline_level1">
                <HBox margin="0,1,0,0" mouse="false" width="auto" height="auto" halign="left">
                    <ButtonEx name="display_name_button" class="tab_header_button"
                              width="200" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_NAME"/>
                    <ButtonEx name="publisher_button" class="tab_header_button"
                              width="200" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_PUBLISHER"/>
                    <ButtonEx name="display_version_button" class="tab_header_button"
                              width="100" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_VERSION"/>
                    <ButtonEx name="registry_time_button" class="tab_header_button"
                              width="150" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_REGISTRY_UPDATE_TIME"/>
                    <ButtonEx name="install_date_button" class="tab_header_button"
                              width="100" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_INSTALL_DATE"/>
                    <ButtonEx name="registry_name_button" class="tab_header_button"
                              width="300" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_INSTALLED_SOFTWARE_REGISTRY_NAME"/>
                </HBox>
                <VListBox class="list" name="installed_software_list" margin="0,0,0,0" width="stretch" height="stretch"
                          vscrollbar="true" hscrollbar="true"/>
            </VBox>
        </VBox>
    </Box>
</Window>