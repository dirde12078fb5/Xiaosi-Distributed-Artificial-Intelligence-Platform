<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <Box margin="0,0,0,0" valign="center" halign="center" width="stretch" height="stretch">
        <VBox margin="0,0,0,0" padding="25,25,25,25">
            <VBox margin="0,0,0,0" padding="12,12,12,12" height="auto" bkcolor="white" borderround="8,8" bordersize="1"
                  bordercolor="splitline_level1">
                <HBox margin="0,0,0,0" mouse="false" width="stretch" height="auto" halign="right">
                    <HBox width="stretch"/>
					<Button class="normal_button" name="refresh_button" width="auto" minwidth="80" height="30"
								margin="0,0,0,0" valign="center" textid="STRING_REFRESH"/>
				</HBox>
			</VBox>
            <VBox margin="0,25,0,0" padding="12,0,12,12" height="stretch" bkcolor="white" borderround="8,8"
                  bordersize="1" bordercolor="splitline_level1">
                <HBox margin="16,1,0,0" mouse="false" width="auto" height="auto" halign="left">
                    <ButtonEx name="process_exe_button" class="tab_header_button"
                              width="200" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_RECENTLY_CRASH_PROCESS_NAME"/>
                    <ButtonEx name="event_name_button" class="tab_header_button"
                              width="200" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_RECENTLY_CRASH_EVENT_NAME"/>
                    <ButtonEx name="event_time_button" class="tab_header_button"
                              width="200" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_RECENTLY_CRASH_EVENT_TIME"/>
                    <ButtonEx name="process_path_button" class="tab_header_button"
                              width="400" height="30"
                              textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_RECENTLY_CRASH_PROCESS_PATH"/>
                </HBox>
                <VListBox class="list" name="recently_crash_list" margin="0,0,0,0" width="stretch" height="stretch"
                          vscrollbar="true" hscrollbar="true"/>
            </VBox>
        </VBox>
    </Box>
</Window>