<?xml version="1.0" encoding="UTF-8"?>
<Window>
    <ListContainerElement class="listitem"
                          width="stretch" height="auto">
        <VBox width="stretch" height="auto" padding="0,0,0,0"
              bordercolor="color_btn_border" bordersize="0,1,0,0">
            <HBox width="auto" minheight="30" height="stretch" valign="center" halign="left" padding="0,0,0,0"
                  bordercolor="color_btn_border">
                <HBox margin="0,0,0,0" width="16" height="stretch" valign="center" halign="center">
                    <Button class="btn_expand_right" width="16" height="16" name="btn_expand" valign="center"
                            halign="center"/>
                    <Button class="btn_contract" width="16" height="16" name="btn_contract" valign="center"
                            halign="center"/>
                </HBox>
                <Label name="filename_label"
                       margin="4,0,4,0" width="192" height="auto" valign="center" halign="center"
                       align="left" singleline="true" endellipsis="true"/>
                <Label name="process_exe_label"
                       margin="4,0,4,0" width="192" height="auto" valign="center" halign="center"
                       align="left" singleline="true" endellipsis="true"/>
                <Label name="run_counter_label"
                       margin="4,0,4,0" width="92" height="auto" valign="center" halign="center"
                       align="left" singleline="true" endellipsis="true"/>
                <Label name="last_run_time_label"
                       margin="4,0,4,0" width="192" height="auto" valign="center" halign="center"
                       align="left" singleline="true" endellipsis="true"/>
                <Label name="process_path_label"
                       margin="4,0,4,0" width="392" height="auto" valign="center" halign="center"
                       align="left" singleline="true" endellipsis="true"/>
            </HBox>
            <VBox name="detail_box"
                  width="stretch" height="auto" valign="center" halign="left"
                  padding="16,0,0,0"
                  bordercolor="color_btn_border">
                <HBox width="stretch" minheight="30" height="auto" valign="center" halign="left" padding="0,0,0,0"
                      margin="0,0,8,0" bordercolor="color_btn_border" bordersize="0,1,0,0">
                    <Label width="100" height="auto" valign="center" halign="center"
                           align="left,top" singleline="true" endellipsis="true"
                           textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_RECENTLY_RUN_RECENTLY_RUN_TIME"/>
                    <Label name="recent_run_label" width="stretch" height="auto" singleline="false"
                           valign="center" halign="center" align="left,vcenter"/>
                </HBox>
                <HBox width="stretch" minheight="30" height="auto" valign="center" halign="left" padding="0,0,0,0"
                      margin="0,0,8,0" bordercolor="color_btn_border" bordersize="0,1,0,0">
                    <Label width="100" height="auto" valign="center" halign="center"
                           align="left,top" singleline="true" endellipsis="true"
                           textid="STRING_PAGE_ADVANCED_DIAGNOSTICS_RECENTLY_RUN_LOAD_FILE"/>
                    <VListBox name="load_file_list"
                              width="stretch" height="auto" maxheight="200"
                              vscrollbar="true" hscrollbar="false" halign="left" valign="top"/>
                </HBox>
            </VBox>
        </VBox>
    </ListContainerElement>
</Window>