<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<VBox bkcolor="tab_background_color" width="stretch" height="stretch" padding="25,15,25,25">
		<VBox width="stretch" height="auto">
			<!-- General Settings Section -->
			<Label font="system_bold_18" textid="STRING_TAB_SETTING_GENERAL_TITLE" width="auto" height="auto" margin="0,0,0,10"/>
			<VBox bkcolor="white" width="stretch" height="auto" padding="15,15,15,15" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
				<VBox width="stretch" height="auto">
					<Label font="system_14" textid="STRING_TAB_SETTING_LANG" valign="center" width="auto" height="auto"/>
					<Combo class="list" name="combo_select_lang" width="700" height="30" margin="0,8,0,0" padding="10,0,0,0" borderround="10,10" bordersize="1" bordercolor="color_btn_border"/>
				</VBox>
			</VBox>
			
			<!-- Network Settings Section -->
			<Label font="system_bold_18" textid="STRING_TAB_NETWORK_SETTINGS_TITLE" width="auto" height="auto" margin="0,25,0,10"/>
			<VBox bkcolor="white" width="stretch" height="auto" padding="15,15,15,15" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
				<VBox width="stretch" height="auto">
					<Label font="system_14" textid="STRING_TAB_NETWORK_SETTINGS_GEO_CONFIG" valign="center" width="auto" height="auto"/>
					<Combo class="list" name="combo_select_geo" width="700" height="30" margin="0,8,0,0" padding="10,0,0,0" borderround="10,10" bordersize="1" bordercolor="color_btn_border"/>
				</VBox>
				
				<VBox width="stretch" height="auto" margin="0,20,0,0">
					<Label font="system_14" textid="STRING_TAB_NETWORK_SETTINGS_PROXY_TYPE" valign="center" width="auto" height="auto"/>
					<HBox width="stretch" height="auto" margin="0,8,0,0">
						<Combo class="list" name="combo_select_proxy_type" width="700" height="30" padding="10,0,0,0" borderround="10,10" bordersize="1" bordercolor="color_btn_border"/>
						<Control width="15"/>
						<ButtonEx class="btn_blue_font12" textpadding="15,6,15,6" name="btn_save_proxy" textid="STRING_OK" width="auto" height="auto" visible="false"/>
					</HBox>
				</VBox>
				
				<!-- Proxy Address and Port -->
				<HBox width="700" height="auto" margin="0,20,0,0">
					<Label font="system_14" textid="STRING_TAB_NETWORK_SETTINGS_PROXY_ADDRESS" valign="center" halign="left" width="60" height="auto"/>
					<Control width="10"/>
					<Box borderround="10,10" name="proxy_address" bordersize="1" bordercolor="color_btn_border" valign="center" width="280" height="30" disabledcolor="textdefaultdisablecolor">
						<RichEdit name="edit_input" margin="10,0,10,0" valign="center" width="stretch" height="auto" normaltextcolor="black" multiline="false"/>
					</Box>
					<Control width="10"/>
					<Label font="system_14" textid="STRING_TAB_NETWORK_SETTINGS_PROXY_PORT" halign="left" valign="center" width="60" height="auto"/>
					<Control width="10"/>
					<Box borderround="10,10" name="proxy_address_port" bordersize="1" bordercolor="color_btn_border" valign="center" width="270" height="30" disabledcolor="textdefaultdisablecolor">
						<RichEdit name="edit_input" margin="10,0,10,0" valign="center" width="stretch" height="auto" normaltextcolor="black" multiline="false"/>
					</Box>
				</HBox>
				
				<!-- Proxy Authentication -->
				<HBox width="700" height="auto" margin="0,20,0,0">
					<Label font="system_14" textid="STRING_TAB_NETWORK_SETTINGS_PROXY_USERNAME" halign="left" valign="center" width="60" height="auto"/>
					<Control width="10"/>
					<Box borderround="10,10" name="proxy_auth_username" bordersize="1" bordercolor="color_btn_border" valign="center" width="280" height="30" disabledcolor="textdefaultdisablecolor">
						<RichEdit name="edit_input" margin="10,0,10,0" valign="center" width="stretch" height="auto" normaltextcolor="black" multiline="false"/>
					</Box>
					<Control width="10"/>
					<Label font="system_14" textid="STRING_TAB_NETWORK_SETTINGS_PROXY_PASSPORT" halign="left" valign="center" width="60" height="auto"/>
					<Control width="10"/>
					<Box borderround="10,10" name="proxy_auth_passport" bordersize="1" bordercolor="color_btn_border" valign="center" width="270" height="30" disabledcolor="textdefaultdisablecolor">
						<RichEdit name="edit_input" margin="10,0,10,0" valign="center" width="stretch" height="auto" normaltextcolor="black" multiline="false"/>
					</Box>
				</HBox>
			</VBox>
			
			<!-- About Section -->
			<Label font="system_bold_18" textid="STRING_TAB_SETTING_ABOUT" width="auto" height="auto" margin="0,25,0,10"/>
			<VBox bkcolor="white" width="stretch" height="auto" padding="15,15,15,15" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
				<RichEdit font="system_14" name="label_version" text="" width="auto" height="20" readonly="true" multiline="false" normaltextcolor="black"/>
				<RichEdit font="system_14" name="label_device_id" text="" width="auto" height="20" margin="0,10,0,0" readonly="true" multiline="false" normaltextcolor="black"/>
				<!-- Temporarily hidden: User tutorial and Contact Us (contact information not yet ready)
				<HBox width="stretch" height="auto" margin="0,10,0,0">
					<Label font="system_14" textid="STRING_TAB_SETTING_USER_GUIDE" width="auto" height="auto" valign="center"/>
					<ButtonEx class="btn_blue_font12" textpadding="10,4,10,4" name="btn_user_guide" textid="STRING_TAB_SETTING_CLICK_TO_JUMP" width="auto" height="auto" margin="5,0,0,0"/>
				</HBox>
				<HBox width="stretch" height="auto" margin="0,10,0,0">
					<Label font="system_14" textid="STRING_TAB_SETTING_CONTACT_US" width="auto" height="auto" valign="center"/>
					<ButtonEx class="btn_blue_font12" textpadding="10,4,10,4" name="btn_contact_us" textid="STRING_TAB_SETTING_JOIN_GROUP" width="auto" height="auto" margin="5,0,0,0"/>
				</HBox>
				-->
			</VBox>
		</VBox>
	</VBox>
</Window>
