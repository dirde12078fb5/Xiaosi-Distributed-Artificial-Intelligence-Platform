<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box name="window_bg" borderround="6,6" margin="0,0,0,30" width="auto" height="auto" padding="10,10,10,10" halign="center" bordersize="1" minheight="60">
		<HBox margin="20,0,20,0" width="auto" maxwidth="600" height="auto" halign="center" valign="center">
			<Label name="window_icon" margin="0,1,0,0" mouse="false" width="16" height="16" halign="left" valign="top"/>
			<VBox margin="5,0,5,0" width="auto" height="auto" valign="center" name="toast_layout_1" visible="false">
				<Label textpadding="3,0,3,0" name="window_content" halign="left" singleline="false" maxwidth="450" width="auto" height="auto" valign="center"/>
				<ButtonBox class="btn_toast" margin="0,3,0,0" halign="right" name="btn_toast" padding="5,5,5,5" width="auto" height="auto">
					<HBox width="auto" height="auto" halign="center" valign="center" mouse="false">
						<Label name="btn_toast_icon" mouse="false" width="16" valign="center" height="16"/>
						<Label name="btn_toast_text" mouse="false" margin="3,0,0,0" width="auto" valign="center" height="auto"/>
					</HBox>
				</ButtonBox>
			</VBox>
			<HBox margin="5,0,5,0" width="auto" height="auto" valign="center" name="toast_layout_2" visible="false">
				<Label textpadding="3,0,3,0" name="window_content" halign="left" singleline="false" maxwidth="450" width="auto" height="auto" valign="center"/>
				<ButtonBox class="btn_toast" margin="5,0,0,0" halign="right" name="btn_toast" padding="5,5,5,5" width="auto" height="auto" valign="center">
					<HBox width="auto" height="auto" halign="center" valign="center" mouse="false">
						<Label name="btn_toast_icon" mouse="false" width="16" valign="center" height="16"/>
						<Label name="btn_toast_text" mouse="false" margin="3,0,0,0" width="auto" valign="center" height="auto"/>
					</HBox>
				</ButtonBox>
			</HBox>
		</HBox>
		<Button class="btn_wnd_close" valign="top" halign="right" name="toast_cls_btn"/>
	</Box>
</Window>