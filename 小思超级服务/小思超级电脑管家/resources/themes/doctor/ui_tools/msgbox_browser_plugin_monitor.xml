<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box bkcolor="bk_wnd_msg_darkcolor" width="stretch" height="stretch" >
		<VBox bkcolor="white" name="msgbox" width="1000" height="700" valign="center" halign="center" visible="true" borderround="10,10">
			<Button class="btn_wnd_close" valign="top" halign="right" name="msg_cls_btn" margin="0,10,10,0"/>
			<VBox margin="24,4,24,24">
				<Label font="system_bold_20" name="msg_title" width="stretch" height="auto"/>
				<HBox margin="0,4,0,10" height="auto">
					<HBox width="auto" height="auto">
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_BROWSER_TYPE" halign="left" valign="center" width="auto" height="auto"/>
						<Combo vscrollbar="false" margin="5,0,0,0" name="combo_browser_type" valign="center" width="150" height="24" dropboxsize="0,9999999" borderround="4,4" bordersize="1" bordercolor="color_btn_border" bkimage="file='combox.svg' dest='126,0,150,24'"/>
					</HBox>
					<Control name="stretch"/>
					<ButtonEx class="normal_button" margin="10,0,0,0" valign="center" halign="right" textpadding="20,0,20,0" width="auto" height="30" name="btn_refresh" textid="STRING_REFRESH"/>
				</HBox>
				<VBox padding="15,0,15,15" width="stretch" height="stretch" name="result" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
					<HBox height="30">
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_PROFILE" width="100" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_PLUGIN_NAME" width="180" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_PLUGIN_ID" width="220" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_VERSION" width="80" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_DESCRIPTION" width="stretch" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_STATUS" width="80" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_BROWSER_PLUGIN_MONITOR_INCOMPATIBLE" width="100" font="system_bold_12" align="left" valign="center"/>
					</HBox>
					<Control class="splitline_hor_level1"/>
					<VListBox vscrollbar="true" name="plugin_list" width="stretch" height="stretch" valign="center"/>
				</VBox>
			</VBox>
		</VBox>
	</Box>
</Window>
