<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box bkcolor="bk_wnd_msg_darkcolor" width="stretch" height="stretch">
		<VBox bkcolor="white" name="msgbox" width="1000" height="758" valign="center" halign="center" visible="true" borderround="10,10">
			<Button class="btn_wnd_close" valign="top" halign="right" name="msg_cls_btn" margin="0,10,10,0"/>
			<VBox margin="24,4,24,24">
				<Label font="system_bold_20" name="msg_title" width="stretch" height="auto"/>
				<HBox margin="0,4,0,10" height="auto">
					<CheckBox class="checkbox_normal" width="auto" valign="center" name="checkbox_auto_scroll" textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_AUTO_SCROLL"/>
					<Control name="stretch"/>
					<ButtonEx class="normal_button" valign="center" halign="right" textpadding="20,0,20,0" width="auto" height="30" name="btn_monitor_start" textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_START"/>
					<ButtonEx class="normal_button" valign="center" halign="right" textpadding="20,0,20,0" width="auto" height="30" name="btn_monitor_stop" textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_STOP"/>
					<ButtonEx class="normal_button" margin="10,0,0,0" valign="center" halign="right" textpadding="20,0,20,0" width="auto" height="30" name="btn_clean" textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_CLEAN"/>
				</HBox>
				<VBox padding="15,15,15,15" width="stretch" height="stretch" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
					<Label width="auto" height="auto" margin="0,0,0,5" textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_NOTICE" valign="center" halign="left" textpadding="0,0,2,0"/>
					<Control class="splitline_hor_level1"/>
					<HBox height="30">
						<Label textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_TIME" width="100" font="system_bold_12" align="left" valign="center"/>
						<Label text="PID" width="100" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_NAME" width="200" font="system_bold_12" align="left" valign="center"/>
						<Label textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_TYPE" width="stretch" font="system_bold_12" align="left" valign="center"/>
					</HBox>
					<Control class="splitline_hor_level1"/>
					<VListBox vscrollbar="true" name="monitor_list" width="stretch" height="stretch" valign="center"/>
				</VBox>
				<VBox padding="15,15,15,15" margin="0,10,0,0" width="stretch" height="stretch" borderround="8,8" bordersize="1" bordercolor="splitline_level1">
					<Label width="auto" height="auto" margin="0,0,0,5" textid="STRING_TAB_TOOLS_SYSTEM_MONITOR_SUB_MONITOR_CLIPBOARD_PREVIEW" valign="center" halign="left" textpadding="0,0,2,0"/>
					<Control class="splitline_hor_level1"/>
					<PreviewControl margin="0,2,0,0" name="monitor_preview" width="stretch" height="stretch"/>
				</VBox>
			</VBox>
		</VBox>
	</Box>
</Window>