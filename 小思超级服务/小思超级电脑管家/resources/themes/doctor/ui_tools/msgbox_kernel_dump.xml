<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box bkcolor="bk_wnd_msg_darkcolor" width="stretch" height="stretch">
		<VBox bkcolor="white" name="msgbox" width="420" height="210" valign="center" halign="center" visible="true" borderround="10,10">
			<Button class="btn_wnd_close" valign="top" halign="right" name="msg_cls_btn" margin="0,10,10,0"/>
			<VBox margin="24,4,24,24">
			<!-- Title with help tooltip -->
			<HBox width="stretch" height="auto">
				<Label font="system_bold_20" name="msg_title" width="auto" height="auto"/>
				<Label name="msg_title_help"
				       width="auto"
				       height="auto"
				       margin="8,0,0,0"
				       text="?"
				       font="system_bold_20"
				       normaltextcolor="gray"
				       hotcolor="color_text_item_hot"
				       cursortype="hand"
				       tooltiptextid="STRING_KERNEL_DUMP_TIP_FULL_DUMP_SIZE"/>
			</HBox>

				<VBox margin="10,6,0,0">
					<CheckBox class="checkbox_normal" name="chk_capture_user_pages" textid="STRING_KERNEL_DUMP_CAPTURE_USER_STACK" width="auto" height="auto"/>
					<CheckBox class="checkbox_normal" name="chk_capture_hv_pages" textid="STRING_KERNEL_DUMP_CAPTURE_VIRTUALIZATION_INFO" width="auto" height="auto"/>
					<CheckBox class="checkbox_normal" name="chk_capture_only_kernel_thread_stacks" textid="STRING_KERNEL_DUMP_CAPTURE_KERNEL_STACKS_ONLY" width="auto" height="auto" visible="false"/>

					<!-- Canceling tip -->
					<Label name="canceling_tip" visible="false" margin="0,8,0,0" font="system_14" normaltextcolor="gray" textid="STRING_KERNEL_DUMP_CANCELING"/>
				</VBox>

				<HBox margin="10,16,0,0" height="30">
					<Control width="stretch"/>
					<!-- saving spinner -->
					<Label name="ico_status" visible="false" margin="0,0,10,0" mouse="false" width="24" height="24" halign="center" valign="center" bkimage="..\public\animation\ani_loading_ex.gif"/>
					<ButtonEx class="normal_button" textpadding="20,0,20,0" width="auto" height="30" name="btn_save" textid="STRING_KERNEL_DUMP_SAVE"/>
					<ButtonEx class="normal_button" textpadding="20,0,20,0" width="auto" height="30" margin="8,0,0,0" name="btn_cancel" textid="STRING_CANCEL"/>
				</HBox>
			</VBox>
		</VBox>
	</Box>
</Window>
