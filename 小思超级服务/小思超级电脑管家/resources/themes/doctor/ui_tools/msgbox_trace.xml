<?xml version="1.0" encoding="UTF-8"?>
<Window>
	<Box bkcolor="bk_wnd_msg_darkcolor" width="stretch" height="stretch">
		<VBox bkcolor="white" name="msgbox" width="350" height="240" valign="center" halign="center" visible="true" borderround="10,10">
			<Button class="btn_wnd_close" valign="top" halign="right" name="msg_cls_btn" margin="0,10,10,0"/>
			<VBox margin="24,4,24,24">
				<Label font="system_bold_20" name="msg_title" width="stretch" height="auto"/>
				<Control name="stretch" height="24"/>
				<Label font="system_bold_40" margin="0,0,0,0" name="msg_content1" text="00:00" width="auto" halign="center" height="auto"/>
				<Control name="stretch"/>
				<HBox name="box_start" margin="0,0,0,0" halign="center" width="auto" height="auto">
					<ButtonBox class="btn_trace" name="start_trace_btn" width="100" height="50">
						<Label mouse="false" name="ico" width="auto" valign="center" halign="center" height="auto" disablefade="true" bkimage="ui_tools\start_icon.svg"/>
					</ButtonBox>
				</HBox>
				<HBox name="box_runing" margin="0,0,0,0" halign="center" width="auto" height="auto">
					<ButtonBox class="btn_trace" name="cancel_trace_btn" width="50" height="50">
						<Label mouse="false" name="ico" width="auto" valign="center" halign="center" height="auto" disablefade="true" bkimage="ui_tools\cancel_icon.svg"/>
					</ButtonBox>
					<Control name="stretch" width="60"/>
					<ButtonBox class="btn_trace" name="save_save_btn" width="50" height="50">
						<Label mouse="false" name="ico" width="auto" valign="center" halign="center" height="auto" disablefade="true" bkimage="ui_tools\save_icon.svg"/>
					</ButtonBox>
				</HBox>
			</VBox>
		</VBox>
	</Box>
</Window>